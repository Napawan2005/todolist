<%# title ใช้ชื่อ task จริงๆ %>
<% content_for :title, @task.title %>

<%# flash notice เช่น "Task was successfully updated." %>
<% if notice.present? %>
  <p class="flash-notice"><%= notice %></p>
<% end %>

<%# header หน้า show %>
<div class="page-header">
  <div class="page-header-left">
    <p class="page-label">Detail</p>
    <h1>📋 Task</h1>
  </div>
</div>

<%# กล่องขาวใส่รายละเอียด %>
<div class="detail-card">

  <%# กล่อง amber ใส่ชื่อ task มีเส้นสีเหลืองซ้าย %>
  <div class="detail-title-box">
    <div class="detail-label">Title</div>
    <div class="detail-value"><%= @task.title %></div>
  </div>

  <%# แถวข้อมูล 2 กล่อง: due date + status %>
  <div class="detail-meta">

    <div class="detail-meta-box">
      <div class="detail-label">Due Date</div>
      <div class="detail-value">
        <%# ถ้าไม่มีวันกำหนด แสดง — แทน %>
        <%= @task.due_date.present? ? @task.due_date.strftime("%-d %b %Y") : "—" %>
      </div>
    </div>

    <div class="detail-meta-box">
      <div class="detail-label">Status</div>
      <div class="detail-value">
        <%= @task.completed ? "✅ Done" : "⏳ Pending" %>
      </div>
    </div>

  </div>
</div>

<%# ปุ่ม action 3 ปุ่ม %>
<div class="btn-group">
  <%# Edit — ไปหน้า edit %>
  <%= link_to "Edit", edit_task_path(@task), class: "btn btn-primary" %>

  <%# Delete — button_to ส่ง DELETE request, turbo_confirm แสดง dialog ยืนยัน %>
  <%= button_to "Delete", @task, method: :delete, class: "btn btn-danger",
      data: { turbo_confirm: "Delete this task?" } %>

  <%# Back — กลับหน้า index %>
  <%= link_to "← Back", tasks_path, class: "btn btn-secondary" %>
</div>
