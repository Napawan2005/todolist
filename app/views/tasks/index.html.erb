<% content_for :title, "Tasks" %>

<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<div class="page-header">
  <h1>My Tasks</h1>
  <%= link_to "New Task", new_task_path, class: "btn btn-primary" %>
</div>

<div id="tasks">
  <% @tasks.each do |task| %>
    <div class="task-item">
      <input type="checkbox" disabled <%= "checked" if task.completed %>>

      <span class="task-title <%= 'completed' if task.completed %>">
        <%= task.title %>
      </span>

      <% if task.due_date.present? %>
        <span class="task-due-date"><%= task.due_date.strftime("%d %b %Y") %></span>
      <% end %>

      <span class="task-badge <%= task.completed ? 'badge-done' : 'badge-pending' %>">
        <%= task.completed ? "Done" : "Pending" %>
      </span>

      <div class="actions" style="margin-top:0">
        <%= link_to "View", task, class: "btn btn-secondary btn-sm" %>
        <%= link_to "Edit", edit_task_path(task), class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  <% end %>
</div>
