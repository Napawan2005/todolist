<%# บอก Rails ว่า title ของหน้านี้คืออะไร (ใส่ใน <title> tag) %>
<% content_for :title, "My Tasks" %>

<%# แสดง flash notice ถ้ามี (เช่น "Task was successfully created.") %>
<% if notice.present? %>
  <p class="flash-notice"><%= notice %></p>
<% end %>

<%# PAGE HEADER: ชื่อหน้าซ้าย + ปุ่ม New Task ขวา %>
<div class="page-header">
  <div class="page-header-left">
    <p class="page-label">Today</p>
    <h1>🌈 My Tasks</h1>
  </div>
  <%# link_to = สร้าง <a> tag, new_task_path = /tasks/new %>
  <%= link_to "＋ New Task", new_task_path, class: "btn btn-primary" %>
</div>

<%# คำนวณ % ที่เสร็จแล้ว สำหรับ progress bar %>
<%
  total     = @tasks.count
  completed = @tasks.count(&:completed)
  pct       = total > 0 ? (completed * 100 / total) : 0
%>

<%# PROGRESS BAR: width set แบบ inline ตาม % ที่คำนวณ %>
<div class="progress-wrap">
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" style="width: <%= pct %>%"></div>
  </div>
</div>
<span class="progress-label"><%= completed %> of <%= total %> completed</span>

<%= render "profile_chip", profile: @profile %>

<%# วน loop แต่ละ task %>
<div id="tasks">
  <% @tasks.each do |task| %>
    <%
      if task.completed
        row_class = "done"      # สีฟ้า
        icon      = "✅"
      elsif task.due_date.present? && task.due_date < Date.today
        row_class = "pending"   # สีเหลือง — เลยกำหนดแล้ว
        icon      = "⏰"
      else
        row_class = "upcoming"  # สีชมพู — ยังไม่ถึงกำหนด
        icon      = "📌"
      end
    %>

    <%# task-row + class สี ตาม status %>
    <div class="task-row <%= row_class %>">

      <%# icon บอก status %>
      <span class="task-icon"><%= icon %></span>

      <%# ข้อมูล task: ชื่อ + วันกำหนด %>
      <div class="task-info">
        <div class="task-name <%= 'strikethrough' if task.completed %>">
          <%= task.title %>
        </div>
        <% if task.due_date.present? %>
          <%# strftime = จัดรูปแบบวันที่ เช่น "26 Apr 2026" %>
          <div class="task-date"><%= task.due_date.strftime("%-d %b %Y") %></div>
        <% end %>
      </div>

      <%# ปุ่ม View และ Edit %>
      <div class="btn-group">
        <%= link_to "View", task, class: "btn btn-secondary btn-sm" %>
        <%= link_to "Edit", edit_task_path(task), class: "btn btn-primary btn-sm" %>
      </div>

    </div>
  <% end %>
</div>
