<%# title ของ browser tab %>
<% content_for :title, "New Task" %>

<%# header หน้า new %>
<div class="page-header">
  <div class="page-header-left">
    <p class="page-label">Create</p>
    <h1>✨ New Task</h1>
  </div>
</div>

<%# render partial _form.html.erb — ส่ง @task เข้าไป %>
<%= render "form", task: @task %>

<%# ลิงก์กลับ — link_to สร้าง <a href="/tasks"> %>
<%= link_to "← Back to tasks", tasks_path, class: "back-link" %>
